{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global site settings and content",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "description": { "type": "string" },
        "heroText": { "type": "string" },
        "heroImage": { "type": "string" },
        "heroImages": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 10
        },
        "aboutText": { "type": "string" },
        "experience": { "type": "string" },
        "specialties": { "type": "string" },
        "tools": { "type": "string" },
        "whatsapp": { "type": "string" },
        "email": { "type": "string" },
        "instagram": { "type": "string" },
        "logoUrl": { "type": "string" }
      }
    },
    "Project": {
      "title": "Project",
      "description": "A portfolio project",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "imageUrl", "createdAt"]
    },
    "Category": {
      "title": "Category",
      "description": "A project category",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "Testimonial": {
      "title": "Testimonial",
      "description": "A client testimonial",
      "type": "object",
      "properties": {
        "clientName": { "type": "string" },
        "clientPhoto": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientName", "rating", "comment", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A contact form message",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "message", "createdAt"]
    },
    "Lead": {
      "title": "Lead",
      "description": "A captured lead from the popup form",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "whatsapp": { "type": "string" },
        "service": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "whatsapp", "service", "description", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/settings/{settingId}": {
      "schema": { "$ref": "#/entities/Settings" },
      "description": "Global settings (singleton document 'global')"
    },
    "/projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "Portfolio projects"
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Project categories"
    },
    "/testimonials/{testimonialId}": {
      "schema": { "$ref": "#/entities/Testimonial" },
      "description": "Client testimonials"
    },
    "/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Contact form messages"
    },
    "/leads/{leadId}": {
      "schema": { "$ref": "#/entities/Lead" },
      "description": "Captured leads"
    }
  }
}
